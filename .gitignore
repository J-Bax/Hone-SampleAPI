# =============================================================================
# SampleApi .gitignore
# =============================================================================

# ----- .NET / C# -----
bin/
obj/
*.user
*.suo
*.userosscache
*.sln.docstates
*.userprefs
[Dd]ebug/
[Rr]elease/
x64/
x86/
**/Properties/launchSettings.json

# NuGet
*.nupkg
**/packages/*
!**/packages/build/
*.nuget.props
*.nuget.targets
project.lock.json

# ----- SQL Server -----
*.mdf
*.ldf

# ----- IDE / Editor -----
.vs/
.vscode/settings.json
.vscode/launch.json
*.swp
*.swo
*~
.idea/

# ----- OS -----
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store

# ----- Results -----
# Performance results, logs, and reports are generated per-run
results/*
!results/.gitkeep
