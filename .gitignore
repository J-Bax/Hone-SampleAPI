# =============================================================================
# SampleApi .gitignore
# =============================================================================

# ----- .NET / C# -----
bin/
obj/
*.user
*.suo
*.userosscache
*.sln.docstates
*.userprefs
[Dd]ebug/
[Rr]elease/
x64/
x86/
**/Properties/launchSettings.json

# NuGet
*.nupkg
**/packages/*
!**/packages/build/
*.nuget.props
*.nuget.targets
project.lock.json

# ----- SQL Server -----
*.mdf
*.ldf

# ----- IDE / Editor -----
.vs/
.vscode/settings.json
.vscode/launch.json
*.swp
*.swo
*~
.idea/

# ----- OS -----
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store

# ----- Hone results -----
# Default: ignore everything in .hone/results/
.hone/results/*
!.hone/results/.gitkeep
!.hone/results/baseline/
.hone/results/baseline/*
!.hone/results/baseline/k6-summary.json
!.hone/results/run-metadata.json
!.hone/results/hone.jsonl
!.hone/results/metadata/

# Experiment directories — commit agent analysis and metrics, ignore raw profiling data
!.hone/results/experiment-*/
# Ignore raw profiling collector output (large binaries, ETLs, CSVs, export logs)
# but keep parsed summary JSONs via specific negations
.hone/results/experiment-*/diagnostics/perfview-cpu/
.hone/results/experiment-*/diagnostics/perfview/
.hone/results/experiment-*/diagnostics/k6-*.json
# perfview-gc: ignore dir, then un-ignore just gc-report.json
.hone/results/experiment-*/diagnostics/perfview-gc/*
!.hone/results/experiment-*/diagnostics/perfview-gc/gc-report.json
# dotnet-counters: ignore dir, then un-ignore just dotnet-counters.json
.hone/results/experiment-*/diagnostics/dotnet-counters/*
!.hone/results/experiment-*/diagnostics/dotnet-counters/dotnet-counters.json

