# =============================================================================
# SampleApi .gitignore
# =============================================================================

# ----- .NET / C# -----
bin/
obj/
*.user
*.suo
*.userosscache
*.sln.docstates
*.userprefs
[Dd]ebug/
[Rr]elease/
x64/
x86/
**/Properties/launchSettings.json

# NuGet
*.nupkg
**/packages/*
!**/packages/build/
*.nuget.props
*.nuget.targets
project.lock.json

# ----- SQL Server -----
*.mdf
*.ldf

# ----- IDE / Editor -----
.vs/
.vscode/settings.json
.vscode/launch.json
*.swp
*.swo
*~
.idea/

# ----- OS -----
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store

# ----- Results -----
# Default: ignore everything in results/
results/*
!results/.gitkeep
!results/baseline.json
!results/baseline-*.json
!results/run-metadata.json
!results/hone.jsonl
!results/metadata/

# Experiment directories — commit agent analysis, ignore raw profiling data
!results/experiment-*/
results/experiment-*/k6-*.json
results/experiment-*/diagnostics/perfview-cpu/
results/experiment-*/diagnostics/perfview-gc/
results/experiment-*/diagnostics/perfview/
results/experiment-*/diagnostics/dotnet-counters/
results/experiment-*/diagnostics/k6-*.json
