# =============================================================================
# SampleApi .gitignore
# =============================================================================

# ----- .NET / C# -----
bin/
obj/
*.user
*.suo
*.userosscache
*.sln.docstates
*.userprefs
[Dd]ebug/
[Rr]elease/
x64/
x86/
**/Properties/launchSettings.json

# NuGet
*.nupkg
**/packages/*
!**/packages/build/
*.nuget.props
*.nuget.targets
project.lock.json

# ----- SQL Server -----
*.mdf
*.ldf

# ----- IDE / Editor -----
.vs/
.vscode/settings.json
.vscode/launch.json
*.swp
*.swo
*~
.idea/

# ----- OS -----
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store

# ----- Results -----
# Baselines, k6 summaries, and run metadata are committed for review.
# Counters, Copilot logs, dashboard, and operational files are gitignored.
results/*
!results/.gitkeep
!results/baseline.json
!results/baseline-*.json
!results/run-metadata.json
!results/metadata/
!results/iteration-*/
results/iteration-*/*
!results/iteration-*/k6-summary*.json
!results/iteration-*/root-cause.md
